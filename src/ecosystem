#------------------------------------------------------------------------------
# 4) LOAD METADATA
#------------------------------------------------------------------------------
# Load the metadata table associated with the ecosystem raster
# This table translates numeric raster values into ecosystem descriptions,
# climate regions, and other ecological information

metadata_eco <- read.delim("/Users/saraterribilini/Desktop/UNINE/2st semester/Biodiversity data analysis/Vstudio/my project/data/WorldEcosystem.metadata.tsv")

#Inspection
head(metadata_eco)

#------------------------------------------------------------------------------
# 5) MERGE WITH METADATA
#------------------------------------------------------------------------------


# Merge the occurrence table with the ecosystem metadata
# The column eco_values contains the raster values extracted at each point
# The column Value in the metadata table contains the corresponding ecosystem codes
# This step adds ecosystem information to each species occurrence record
matrix_full_eco <- matrix_full_eco %>%
  left_join(
    metadata_eco,
    by = c("eco_values" = "Value")
  )
#check
head(matrix_full_eco)
dim(matrix_full_eco)
#------------------------------------------------------------------------------
# 6) PLOT
#------------------------------------------------------------------------------
# Create a bar plot showing how many occurrence records of each species
# fall within each climate category
# This allows comparison of the climatic/ecosystem distribution of the species
quartz()
count <- ggplot(matrix_full_eco %>% filter(!is.na(Climate_Re)), aes(x = Climate_Re, fill = species)) +
  geom_bar(position = "dodge") +
  labs(
    title = "Count of Observations of Each Species by Climate",
    x = "Climate category",
    y = "Number of observations"
  ) +
  theme_minimal()

print(count)


