#------------------------------------------------------------------------------
# 3) EXTRACT ECOSYSTEM VALUES
#------------------------------------------------------------------------------

# Extract the raster pixel value at each species occurrence point
# Each extracted value represents the ecosystem class where that occurrence
# point is located
eco_values <- raster::extract(ecosystem_europe, spatial_points)

#Check
