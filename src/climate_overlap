# ============================================================
# SPECIES COMPOSITION ACROSS CLIMATE REGIONS
# Dot plot of relative observation frequency
# ============================================================

# Count the number of observations of each species in each climate region.
# Then calculate the relative frequency of each species within each climate region.
climate_species <- df %>%
  count(Climate_Re, species) %>%
  group_by(Climate_Re) %>%
  mutate(prop = n / sum(n))

# Plot the relative species composition for each climate region.
# Point size represents the relative frequency of each species.
# Percent labels are added to make the differences easier to interpret.

quartz()
plotC <- ggplot(
  climate_species,
  aes(
    x = Climate_Re,
    y = species,
    size = prop,
    color = species,
    label = scales::percent(prop, accuracy = 1))) +
  geom_point(alpha = 0.85) +
  geom_text(
    color = "#f9e2c2",
    fontface = "bold",
    size = 3) +
  scale_size_area(max_size = 18) +
  scale_color_manual(values = species_cols) +
  labs(
    title = "C. Species composition across climate regions",
    x = "Climate region",
    y = NULL) +
  theme_minimal() +
  theme(
    legend.position = "none")

print(plotC)

