(
# ============================================================
#  PLOT A – MAP OF EUROPE
#  Background: ecosystem type from WTE raster
#  Points: species observations
# ============================================================
library(dplyr)
library(sf)
# ============================================================
#  PLOT A – MAP OF EUROPE
#  Background: ecosystem type from WTE raster
#  Points: species observations
# ============================================================
library(dplyr)
library(sf)
library(raster)
library(rnaturalearth)
library(rnaturalearthdata)
sf_use_s2(FALSE)
# ============================================================
# 1. LOAD FINAL DATA MATRIX
# ============================================================
df <- read.csv(
  "/Users/saraterribilini/Desktop/UNINE/2st semester/Biodiversity data analysis/github/final/data/matrix_full_eco_elev_clim_sat_clean.csv",
  stringsAsFactors = FALSE
)
head(df)
colnames(df)
table(df$species)
# ============================================================
# 2. DEFINE EUROPEAN MAP EXTENT
# ============================================================
xmin <- -22
xmax <- 57
ymin <- 30
ymax <- 70
# ============================================================
# 3. LOAD EUROPE BORDERS
# ============================================================
Europe <- ne_countries(
  continent = "Europe",
  scale = "medium",
  returnclass = "sf"
)
# ============================================================
# 4. LOAD ECOSYSTEM RASTER
# ============================================================
# This raster is used directly as background.
# We do NOT convert it to a dataframe. I had too many problems while I was trying to convert the raster in df.
ecosystem_europe <- raster(
  "/Users/saraterribilini/Desktop/UNINE/2st semester/Biodiversity data analysis/Vstudio/my project/data/WorldEcosystem.tif"
)
# ============================================================
# 5. CROP RASTER TO EUROPEAN EXTENT
# ============================================================
# This makes plotting faster because we keep only Europe.
europe_extent <- extent(xmin, xmax, ymin, ymax)
ecosystem_europe_crop <- crop(
  ecosystem_europe,
  europe_extent
)
# ============================================================
# 6. PREPARE SPECIES POINTS
# ============================================================
# Remove rows without coordinates or species name.
df_points <- df %>%
  filter(
    !is.na(longitude),
    !is.na(latitude),
    !is.na(species)
  )
# Convert coordinates into SpatialPoints.
# This allows us to overlay them directly on the raster map.
spatial_points <- SpatialPoints(
  coords = df_points[, c("longitude", "latitude")],
  proj4string = CRS("+proj=longlat +datum=WGS84")
)
# ============================================================
# 7. DEFINE COLORS AND SYMBOLS FOR SPECIES
# ============================================================
species_cols <- c(
  "Cuculus canorus" = "#1d3557",
  "Prunella modularis" = "#e63946",
  "Acrocephalus scirpaceus" = "#2a9d8f"
)
species_pch <- c(
  "Cuculus canorus" = 16,
  "Prunella modularis" = 17,
  "Acrocephalus scirpaceus" = 15
)
point_cols <- species_cols[df_points$species]
point_pch  <- species_pch[df_points$species]
# ============================================================
# 8. PLOT MAP
# ============================================================
# First layer: ecosystem raster background
# Second layer: Europe borders
# Third layer: species occurrence points
quartz()
plot(
  ecosystem_europe_crop,
  main = "A. Species observations across European ecosystem types",
  xlim = c(xmin, xmax),
  ylim = c(ymin, ymax),
  axes = TRUE,
  box = TRUE
)
plot(
  st_geometry(Europe),
  add = TRUE,
  border = "grey20",
  lwd = 0.5
)
plot(
  spatial_points,
  add = TRUE,
  pch = point_pch,
  col = point_cols,
  cex = 0.45
)
legend(
  "right",
  legend = names(species_cols),
  col = species_cols,
  pch = species_pch,
  bty = "n",
  title = "Species"
)
